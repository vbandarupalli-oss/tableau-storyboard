<?xml version="1.0" encoding="utf-8"?>
<manifest manifest-version="0.1" xmlns="http://www.tableau.com/xml/extension_manifest">
  <dashboard-extension id="com.vbandarupalli.tableau.storyboard" extension-version="1.0.0">
    <default-locale>en_US</default-locale>
    <name>Dashboard Storyboard</name>
    <description>Transforms any Tableau dashboard into a plain-English storyboard narrative for business consumers. Powered by Claude AI.</description>
    <author name="vbandarupalli-oss" email="vbandarupalli@salesforce.com" organization="Tableau Storyboard" website="https://github.com/vbandarupalli-oss"/>
    <min-api-version>1.7</min-api-version>
    <source-location>
      <url>https://vbandarupalli-oss.github.io/tableau-storyboard/</url>
    </source-location>
    <icon>iVBORw0KGgoAAAANSUhEUgAAABAAAAAQCAYAAAAf8/9hAAAAFUlEQVQ4jWNgYGD4z8BQDwAEAAH/AL5TQ6sAAAAASUVORK5CYII=</icon>
    <permissions>
      <permission>full data</permission>
    </permissions>
  </dashboard-extension>
</manifest>
